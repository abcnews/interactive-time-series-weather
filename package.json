    "@abcnews/components-storylab": "^0.0.1",
    "@abcnews/env-utils": "^6.0.0",
    "@abcnews/mount-utils": "^3.0.0",
    "@types/geojson": "^7946.0.16",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "layercake": "^8.4.2",
    "svelte": "^5.46.0",
